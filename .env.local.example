# Playable Agent Fighter client (production deploy, or npm run play → localhost:8475)
NEXT_PUBLIC_GAME_URL=https://agent-fighter.vercel.app

# Agent Fighter Supabase (public leaderboard view — same project as the match server)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Prefer the anon/publishable key (RLS allows public SELECT on leaderboard).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: ask-gate lead capture + local leaderboard fallback (never commit / never NEXT_PUBLIC_)
SUPABASE_SERVICE_KEY=
